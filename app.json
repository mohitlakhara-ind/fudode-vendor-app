{
  "expo": {
    "name": "fudode-vendor-app",
    "slug": "fudode-vendor-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fudodevendorapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fudodeoffice.fudodevendorapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fudode needs location access to pinpoint your store on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Fudode needs location access to pinpoint your store on the map.",
        "NSLocationAlwaysUsageDescription": "Fudode needs location access to pinpoint your store on the map.",
        "NSPhotoLibraryUsageDescription": "Fudode needs access to your photo library for uploading KYC documents."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyBGAVQXKTGQkoMhM8zCMf6vPhSYZyDbFJw"
      }
    },
    "android": {
      "package": "com.fudodeoffice.fudodevendorapp",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBGAVQXKTGQkoMhM8zCMf6vPhSYZyDbFJw"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "shrinkResources": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Fudode needs location access to pinpoint your store on the map.",
          "locationWhenInUsePermission": "Fudode needs location access to pinpoint your store on the map."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}